-- | Tests for the `PaidQuoteVerifier` interface against real secp256k1 keys and
-- the genuine Canton Token Standard V1 settlement path. Each script generates a
-- keypair with `secp256k1generatekeypair`, signs the canonical text of a paid
-- payload (which includes the cost) with `secp256k1sign`, and exercises
-- `PaidQuoteVerifier_VerifyAndPay` against a verifier created with the matching public key and a
-- pinned payee. The fee settles to a treasury distinct from the signing oracle
-- through the test token registry, with the treasury supplying a standing
-- preapproval. Negative cases assert the specific abort message so each failure
-- is shown to be for its intended reason.
--
-- The happy path also checks the durable `AuditRecord` the verify choice writes
-- on success: that both the verifying party (its observer) and the producer (its
-- signatory) see one record, and that it carries the verified quote, the
-- signature evidence, and the settled fee, instrument, and payee. The failure
-- cases check that an aborted verification writes no record.
module Test.PaidQuoteVerifierV1Test where

import DA.Assert ((===))
import DA.Crypto.Text (toHex)
import DA.Time (addRelTime, hours, minutes)
import qualified DA.TextMap as TM
import Daml.Script

import DataStandard.PaidQuoteVerifierV1
import qualified DataStandard.PaidQuoteVerifierAuditV1 as Audit
import DataStandard.Utils (Quote(..))

import Splice.Api.Token.HoldingV1 (Holding, InstrumentId(..))
import Splice.Api.Token.MetadataV1
import Splice.Api.Token.TransferInstructionV1
  ( TransferFactory
  , TransferFactoryView(..)
  , TransferInstructionResult(..)
  , TransferInstructionResult_Output(..)
  )
import TestTokenRegistry.Registry
import PaidVerifierProducer.SignatureVerifier
import PaidVerifierConsumer.Trading
import Test.Fixtures (submitFailsWith, expectAbort)

-- | A staged paid verifier: a real keypair, the on-ledger paid verifier holding
-- the public key and pinning a treasury payee, a funded buyer/payer, the
-- treasury's standing preapproval, the registry's transfer factory, and every
-- disclosure the buyer needs to reach the oracle-signed verifier, the
-- admin-signed factory, and the treasury-signed preapproval in one submission.
data PaidFixture = PaidFixture with
    oracle : Party
    treasury : Party
    buyer : Party
    admin : Party
    keyPair : Secp256k1KeyPair
    instrumentId : InstrumentId
    verifierTpl : ContractId PaidSignatureVerifier
    verifierIf : ContractId PaidQuoteVerifier
    verifierDisc : Disclosure
    buyerHoldingCid : ContractId RegistryHolding
    factoryCid : ContractId TransferFactory
    factoryDisc : Disclosure
    preapprovalCid : ContractId TransferPreapproval
    preapprovalDisc : Disclosure

-- | The fee every default payload quotes, in USD issued by the registry admin.
defaultFee : Decimal
defaultFee = 5.0

-- | Stage the fixture: allocate parties, generate a keypair, publish the paid
-- verifier with the treasury as payee, fund the buyer with a holding, stand up
-- the factory, and have the treasury publish a preapproval — capturing the
-- disclosures the buyer submits with.
setup : Script PaidFixture
setup = setupWith True

-- | As `setup`, publishing the verifier with the given `allowsAuditRecords`
-- policy so a test can pin either side of the audit double gate.
setupWith : Bool -> Script PaidFixture
setupWith allowsAuditRecords = do
  oracle <- allocateParty "Oracle"
  treasury <- allocateParty "Treasury"
  buyer <- allocateParty "Buyer"
  admin <- allocateParty "RegistryAdmin"
  keyPair <- secp256k1generatekeypair
  let instrumentId = InstrumentId with admin, id = "USD"

  verifierTpl <- submit oracle $ createCmd PaidSignatureVerifier with
    oracle, payee = treasury, publicKey = keyPair.publicKey, allowsAuditRecords
  Some verifierDisc <- queryDisclosure oracle verifierTpl

  buyerHoldingCid <- submit admin $ createCmd RegistryHolding with
    admin, owner = buyer, instrumentId, amount = 100.0

  factoryTplCid <- submit admin $ createCmd RegistryTransferFactory with admin
  let factoryCid = toInterfaceContractId @TransferFactory factoryTplCid
  Some factoryDisc <- queryDisclosure admin factoryTplCid

  preapprovalCid <- submit treasury $ createCmd TransferPreapproval with
    admin, receiver = treasury, instrumentId
  Some preapprovalDisc <- queryDisclosure treasury preapprovalCid

  pure PaidFixture with
    oracle, treasury, buyer, admin, keyPair, instrumentId
    verifierTpl
    verifierIf = toInterfaceContractId @PaidQuoteVerifier verifierTpl
    verifierDisc, buyerHoldingCid, factoryCid, factoryDisc
    preapprovalCid, preapprovalDisc

-- | A standard, valid paid payload: BTC/USD @ 65000, a 5 USD fee on the
-- fixture's instrument, the fee committed to the fixture treasury (the payee the
-- verifier pins), published now, expiring in 1h.
defaultPayload : PaidFixture -> Time -> PaidSignedPayload
defaultPayload f now = PaidSignedPayload with
  publishedAt = now
  expiresAt   = addRelTime now (hours 1)
  cost = Cost with
    fee = defaultFee
    instrument = f.instrumentId
  payee = f.treasury
  quote = Quote with
    feedId    = "BTC/USD"
    price     = 65000.0
    priceTime = addRelTime now (minutes (-1))

-- | Sign a paid payload's canonical text with a private key, producing the same
-- signature the producer would off-ledger. `secp256k1sign` SHA-256s the
-- hex-encoded message internally, matching the on-ledger `secp256k1` check.
signPaid : Text -> PaidSignedPayload -> Script Text
signPaid privateKey payload =
  secp256k1sign privateKey (toHex (paidCanonicalText payload))

-- | The payment args carrying the buyer's holding and the treasury's preapproval
-- in the standard choice context under the registry's well-known key.
paymentArgs : PaidFixture -> PaymentArgs
paymentArgs f = PaymentArgs with
  transferFactoryCid = f.factoryCid
  inputHoldingCids = [toInterfaceContractId @Holding f.buyerHoldingCid]
  context = ExtraArgs with
    context = ChoiceContext with
      values = TM.fromList
        [ (preapprovalContextKey, AV_ContractId (coerceContractId f.preapprovalCid)) ]
    meta = emptyMetadata

-- A valid signature verifies, returns the quote, and settles the fee to the
-- pinned treasury in one step: the buyer's input holding is gone and the
-- treasury holds exactly one new holding for the fee.
testVerifyAndPayHappyPath : Script ()
testVerifyAndPayHappyPath = do
  f <- setup
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload
  verified <- submit
    ( actAs f.buyer
        <> disclose f.verifierDisc
        <> disclose f.factoryDisc
        <> disclose f.preapprovalDisc
    ) $
    exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
      actor = f.buyer, payload, signature = sig, payment = paymentArgs f, createAuditRecord = True

  verified.distributor     === f.oracle
  verified.quote.feedId    === "BTC/USD"
  verified.quote.price     === 65000.0
  verified.publishedAt     === payload.publishedAt
  verified.canonicalHash   === paidCanonicalHash payload
  verified.signature       === sig
  verified.publicKey        === f.keyPair.publicKey

  -- The fee settled to the treasury, not the oracle.
  treasuryHoldings <- query @RegistryHolding f.treasury
  credited <- case treasuryHoldings of
    [(_, h)] -> pure h
    _ -> abort ("expected exactly one treasury holding, got: " <> show (length treasuryHoldings))
  credited.owner === f.treasury
  credited.amount === defaultFee
  credited.instrumentId === f.instrumentId

  -- The buyer's input holding was spent.
  buyerHolding <- queryContractId f.admin f.buyerHoldingCid
  assertMsg "buyer input holding is archived" (buyerHolding == None)

  -- The oracle, distinct from the payee, was credited nothing.
  oracleHoldings <- query @RegistryHolding f.oracle
  assertMsg "oracle (not the payee) receives no fee" (null oracleHoldings)

  -- The paid verification wrote a durable audit record, seen by the verifying
  -- party (its observer), capturing the settled payment alongside the quote.
  record <- queryOneAuditRecord f.buyer
  record.audit.verifier      === f.buyer
  record.audit.distributor   === f.oracle
  record.audit.verifiedAt    === now
  record.audit.publishedAt   === payload.publishedAt
  record.audit.expiresAt     === payload.expiresAt
  record.audit.canonicalHash === verified.canonicalHash
  record.audit.signature     === sig
  record.audit.publicKey     === f.keyPair.publicKey
  record.quote               === payload.quote
  record.fee                 === payload.cost.fee
  record.instrument          === payload.cost.instrument
  record.payee               === payload.payee

  -- The producer sees the same record from the signatory side.
  producerRecord <- queryOneAuditRecord f.oracle
  producerRecord === record

-- A correctly-signed payload past its expiry is rejected before any payment is
-- attempted: expiry is the sole replay defence.
testExpiredRejected : Script ()
testExpiredRejected = do
  f <- setup
  now <- getTime
  let payload = defaultPayload f now            -- expires now + 1h
  sig <- signPaid f.keyPair.privateKey payload
  passTime (hours 2)                            -- move strictly past expiresAt
  submitFailsWithDiscs f
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = sig, payment = paymentArgs f, createAuditRecord = True)
    "payload expired"
  assertNoAuditRecords f.oracle

-- A signature that does not cover the cost is rejected: the canonical text the
-- signature commits to includes the cost, so signing a payload with a different
-- fee yields a signature that fails to verify the presented payload.
testSignatureNotCoveringCostRejected : Script ()
testSignatureNotCoveringCostRejected = do
  f <- setup
  now <- getTime
  let payload = defaultPayload f now
      otherCost = payload with cost = (payload.cost with fee = 1.0)
  -- Sign the cheaper payload, present the real one: the signature is valid DER
  -- but does not match the presented canonical text.
  wrongSig <- signPaid f.keyPair.privateKey otherCost
  submitFailsWith f.buyer f.verifierDisc
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = wrongSig, payment = paymentArgs f, createAuditRecord = True)
    "invalid signature"

-- A signature does not cover a different payee: signing a payload that names one
-- payee and presenting it with another yields a signature that fails to verify,
-- proving the payee is part of the signed canonical text. This is the companion to
-- testRogueVerifierCannotRedirectFee: that test proves the pinned payee is
-- cross-checked against the signed one, and this proves the signed payee itself
-- cannot be forged to match a substitute verifier.
testSignatureNotCoveringPayeeRejected : Script ()
testSignatureNotCoveringPayeeRejected = do
  f <- setup
  now <- getTime
  let payload = defaultPayload f now
      otherPayee = payload with payee = f.buyer
  -- Sign a payload naming a different payee, present the real one (payee =
  -- treasury): the signature is valid DER but does not match the presented
  -- canonical text, which now binds the payee.
  wrongSig <- signPaid f.keyPair.privateKey otherPayee
  submitFailsWith f.buyer f.verifierDisc
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = wrongSig, payment = paymentArgs f, createAuditRecord = True)
    "invalid signature"

-- A non-positive signed fee is rejected before any settlement. The fee is signed
-- (so the signature check passes), proving `PaidQuoteVerifier_VerifyAndPay` enforces the positive-fee
-- invariant itself rather than leaving it to the registry's amount check.
testZeroFeeRejected : Script ()
testZeroFeeRejected = do
  f <- setup
  now <- getTime
  let base = defaultPayload f now
      payload = base with cost = (base.cost with fee = 0.0)
  sig <- signPaid f.keyPair.privateKey payload
  submitFailsWithDiscs f
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = sig, payment = paymentArgs f, createAuditRecord = True)
    "cost fee must be positive"
  assertNoAuditRecords f.oracle

-- The fee does not settle without the payee's standing preapproval: the registry
-- refuses the transfer, so `PaidQuoteVerifier_VerifyAndPay` aborts and no quote is returned.
testNoPreapprovalRejected : Script ()
testNoPreapprovalRejected = do
  f <- setup
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload
  let noPreapproval = (paymentArgs f) with
        context = ExtraArgs with context = emptyChoiceContext, meta = emptyMetadata
  -- No preapproval disclosed and none supplied in the context: the factory
  -- rejects the transfer on the receiver having no standing preapproval.
  submitFailsWithDiscsNoPreapproval f
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = sig, payment = noPreapproval, createAuditRecord = True)
    "receiver has no standing preapproval for this instrument"

-- The payment instrument must match the signed cost: paying with a holding of a
-- different instrument than the cost names is refused by the registry (the
-- input holding does not match the transfer instrument), so the call aborts and
-- nothing settles.
testPaymentInstrumentMismatchRejected : Script ()
testPaymentInstrumentMismatchRejected = do
  f <- setup
  now <- getTime
  -- The buyer holds EUR; the signed cost is in USD. The transfer is for the
  -- cost's instrument (USD), so the EUR input holding does not match it.
  let eurInstrument = InstrumentId with admin = f.admin, id = "EUR"
  eurHoldingCid <- submit f.admin $ createCmd RegistryHolding with
    admin = f.admin, owner = f.buyer, instrumentId = eurInstrument, amount = 100.0
  let payload = defaultPayload f now            -- cost.instrument = USD
  sig <- signPaid f.keyPair.privateKey payload
  let mismatchedPayment = (paymentArgs f) with
        inputHoldingCids = [toInterfaceContractId @Holding eurHoldingCid]
  submitFailsWithDiscs f
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = sig, payment = mismatchedPayment, createAuditRecord = True)
    "input holding must match the transfer instrument"

-- End-to-end paid verify-and-use: the consumer workflow authenticates a signed
-- quote through a disclosed paid verifier, pays the fee to the treasury, and
-- settles the trade at the verified price in a single transaction.
testConsumerPaidWorkflowHappyPath : Script ()
testConsumerPaidWorkflowHappyPath = do
  f <- setup
  seller <- allocateParty "Seller"
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload
  offer <- submit seller $ createCmd PaidVerifiedQuoteTradeOffer with
    seller, buyer = f.buyer, feedId = "BTC/USD", quantity = 2.0
    expectedDistributor = f.oracle, maxQuoteAge = hours 24
    verifierCid = f.verifierIf
  settlementCid <- submit
    ( actAs f.buyer
        <> disclose f.verifierDisc
        <> disclose f.factoryDisc
        <> disclose f.preapprovalDisc
    ) $
    exerciseCmd offer AcceptPaidVerifiedQuoteTrade with
      payload, signature = sig, payment = paymentArgs f
  Some s <- queryContractId f.buyer settlementCid
  s.price       === 65000.0
  s.totalAmount === 130000.0
  s.feedId      === "BTC/USD"
  s.distributor === f.oracle

  treasuryHoldings <- query @RegistryHolding f.treasury
  assertMsg "the treasury was paid the fee" (length treasuryHoldings == 1)

-- The paid consumer rejects a verified quote from a distributor other than the
-- one the offer pins. The payload verifies and the fee would settle, but the
-- consumer's distributor gate aborts the whole transaction, so nothing settles.
testPaidConsumerUntrustedDistributorRejected : Script ()
testPaidConsumerUntrustedDistributorRejected = do
  f <- setup
  seller <- allocateParty "Seller"
  other  <- allocateParty "OtherOracle"
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload
  offer <- submit seller $ createCmd PaidVerifiedQuoteTradeOffer with
    seller, buyer = f.buyer, feedId = "BTC/USD", quantity = 2.0
    expectedDistributor = other, maxQuoteAge = hours 24
    verifierCid = f.verifierIf
  submitFailsWithDiscs f
    ( exerciseCmd offer AcceptPaidVerifiedQuoteTrade with
        payload, signature = sig, payment = paymentArgs f )
    "untrusted distributor"

  -- The whole transaction rolled back, so the treasury was paid nothing.
  treasuryHoldings <- query @RegistryHolding f.treasury
  assertMsg "no fee settled when the distributor is untrusted" (null treasuryHoldings)

-- The paid consumer rejects a verified quote older than its staleness bound. The
-- payload was produced two hours ago but still has a live window, so it verifies;
-- the consumer's `maxQuoteAge` of one hour rejects it and the fee rolls back.
testPaidConsumerStaleQuoteRejected : Script ()
testPaidConsumerStaleQuoteRejected = do
  f <- setup
  seller <- allocateParty "Seller"
  now <- getTime
  let payload = (defaultPayload f now) with publishedAt = addRelTime now (hours (-2))
  sig <- signPaid f.keyPair.privateKey payload
  offer <- submit seller $ createCmd PaidVerifiedQuoteTradeOffer with
    seller, buyer = f.buyer, feedId = "BTC/USD", quantity = 2.0
    expectedDistributor = f.oracle, maxQuoteAge = hours 1
    verifierCid = f.verifierIf
  submitFailsWithDiscs f
    ( exerciseCmd offer AcceptPaidVerifiedQuoteTrade with
        payload, signature = sig, payment = paymentArgs f )
    "quote too stale"

  treasuryHoldings <- query @RegistryHolding f.treasury
  assertMsg "no fee settled when the quote is stale" (null treasuryHoldings)

-- A paid payload signed with `publishedAt` after `expiresAt` is rejected by the
-- verifier on the well-formedness check, before the expiry check and before any
-- fee is attempted. The window ends before it begins, so it could never be live.
testPaidPublishedAfterExpiryRejected : Script ()
testPaidPublishedAfterExpiryRejected = do
  f <- setup
  now <- getTime
  let payload = (defaultPayload f now) with
        publishedAt = addRelTime now (hours 2)
        expiresAt   = addRelTime now (hours 1)
  sig <- signPaid f.keyPair.privateKey payload
  submitFailsWithDiscs f
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = sig, payment = paymentArgs f, createAuditRecord = True)
    "published after expiry"

  -- Nothing settled: the ill-formed payload aborted before the fee.
  treasuryHoldings <- query @RegistryHolding f.treasury
  assertMsg "no fee settled for an ill-formed window" (null treasuryHoldings)

-- A substitute verifier cannot redirect the fee. The producer's public key is
-- public, so an attacker can deploy their own `PaidQuoteVerifier` holding that
-- key but pinning themselves as payee, then replay a genuine oracle-signed
-- payload through it. The payload's payee is signed (here the fixture treasury),
-- so the signature still verifies against the real key, but the verifier pins a
-- different payee, and `PaidQuoteVerifier_VerifyAndPay` aborts on the payee
-- cross-check rather than settling the fee to the attacker. The abort is
-- specifically "payee mismatch", not a signature error, which is what proves the
-- payee binding (not an incidental mismatch) is the control that blocks the
-- redirect.
testRogueVerifierCannotRedirectFee : Script ()
testRogueVerifierCannotRedirectFee = do
  f <- setup
  attacker <- allocateParty "Attacker"

  -- The attacker deploys their own verifier: the real oracle key, themselves as
  -- payee. They are its signatory, so they can exercise it without disclosure.
  rogueTpl <- submit attacker $ createCmd PaidSignatureVerifier with
    oracle = attacker, payee = attacker, publicKey = f.keyPair.publicKey
    allowsAuditRecords = True
  let rogueIf = toInterfaceContractId @PaidQuoteVerifier rogueTpl

  -- Fund the attacker and let them preapprove receiving the fee to themselves,
  -- so only the payee cross-check (not a missing holding or preapproval) can
  -- stop the redirect.
  attackerHoldingCid <- submit f.admin $ createCmd RegistryHolding with
    admin = f.admin, owner = attacker, instrumentId = f.instrumentId, amount = 100.0
  attackerPreapprovalCid <- submit attacker $ createCmd TransferPreapproval with
    admin = f.admin, receiver = attacker, instrumentId = f.instrumentId
  Some attackerPreapprovalDisc <- queryDisclosure attacker attackerPreapprovalCid

  -- A genuine oracle-signed payload, committed to the fixture treasury.
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload
  let attackerPayment = PaymentArgs with
        transferFactoryCid = f.factoryCid
        inputHoldingCids = [toInterfaceContractId @Holding attackerHoldingCid]
        context = ExtraArgs with
          context = ChoiceContext with
            values = TM.fromList
              [ (preapprovalContextKey, AV_ContractId (coerceContractId attackerPreapprovalCid)) ]
          meta = emptyMetadata

  expectAbort
    ( trySubmit
        ( actAs attacker
            <> disclose f.factoryDisc
            <> disclose attackerPreapprovalDisc
        )
        ( exerciseCmd rogueIf PaidQuoteVerifier_VerifyAndPay with
            actor = attacker, payload, signature = sig, payment = attackerPayment, createAuditRecord = True)
    )
    "payee mismatch"

  -- Nothing settled: the attacker was credited no fee.
  attackerHoldings <- query @RegistryHolding attacker
  assertMsg "no fee was redirected to the attacker"
    (all (\(_, h) -> h.amount /= defaultFee || h.owner /= attacker) attackerHoldings)

-- | A counterfeit transfer factory that models the headline issue-#2 attack: it
-- reports a completed transfer while moving nothing, crediting no receiver
-- holdings.
template NoOpTransferFactory
  with
    operator : Party
  where
    signatory operator

    interface instance TransferFactory for NoOpTransferFactory where
      view = TransferFactoryView with admin = operator, meta = emptyMetadata
      transferFactory_transferImpl _self _arg =
        pure TransferInstructionResult with
          output = TransferInstructionResult_Completed with receiverHoldingCids = []
          senderChangeCids = []
          meta = emptyMetadata
      transferFactory_publicFetchImpl _self _arg =
        pure TransferFactoryView with admin = operator, meta = emptyMetadata

-- A factory that reports completion while crediting no holdings cannot be used to
-- skip the fee. The buyer presents a genuine oracle-signed payload to the genuine
-- verifier but points the payment at a no-op factory it controls, which returns a
-- `Completed` result with an empty receiver-holding set. The choice rejects the
-- settlement on the non-empty-holdings check rather than returning a verified
-- quote, so a quote is never delivered against a transfer that moved nothing. The
-- abort is specifically "fee settlement produced no receiver holdings", proving
-- that check (not an incidental error) is what blocks the skip.
testNoOpTransferFactorySkipRejected : Script ()
testNoOpTransferFactorySkipRejected = do
  f <- setup
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload

  -- The buyer stands up a counterfeit factory it signs, then settles through it.
  noOpFactoryTplCid <- submit f.buyer $ createCmd NoOpTransferFactory with operator = f.buyer
  let noOpFactoryCid = toInterfaceContractId @TransferFactory noOpFactoryTplCid
      skipPayment = (paymentArgs f) with transferFactoryCid = noOpFactoryCid

  submitFailsWith f.buyer f.verifierDisc
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = sig, payment = skipPayment, createAuditRecord = True)
    "fee settlement produced no receiver holdings"

-- The paid consumer rejects a verified quote stamped in the future: it verifies
-- and the fee would settle, but a future publishedAt must not read as fresh, so
-- the consumer's future-age guard aborts and the fee rolls back.
testPaidConsumerFutureDatedQuoteRejected : Script ()
testPaidConsumerFutureDatedQuoteRejected = do
  f <- setup
  seller <- allocateParty "Seller"
  now <- getTime
  let payload = (defaultPayload f now) with
        publishedAt = addRelTime now (hours 2)
        expiresAt   = addRelTime now (hours 3)
  sig <- signPaid f.keyPair.privateKey payload
  offer <- submit seller $ createCmd PaidVerifiedQuoteTradeOffer with
    seller, buyer = f.buyer, feedId = "BTC/USD", quantity = 2.0
    expectedDistributor = f.oracle, maxQuoteAge = hours 24
    verifierCid = f.verifierIf
  submitFailsWithDiscs f
    ( exerciseCmd offer AcceptPaidVerifiedQuoteTrade with
        payload, signature = sig, payment = paymentArgs f )
    "quote published in the future"

  treasuryHoldings <- query @RegistryHolding f.treasury
  assertMsg "no fee settled for a future-dated quote" (null treasuryHoldings)

-- A correctly-signed payload whose instrument id carries the encoding delimiter
-- "|" is rejected before the signature check, the same guard the free verifier
-- applies to feedId. No fee is attempted.
testDelimiterInInstrumentIdRejected : Script ()
testDelimiterInInstrumentIdRejected = do
  f <- setup
  now <- getTime
  let base = defaultPayload f now
      payload = base with
        cost = (base.cost with instrument = (base.cost.instrument with id = "US|D"))
  sig <- signPaid f.keyPair.privateKey payload
  submitFailsWith f.buyer f.verifierDisc
    ( exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
        actor = f.buyer, payload, signature = sig, payment = paymentArgs f, createAuditRecord = True)
    "instrument id contains the reserved delimiter"

-- | As `submitFailsWith`, attaching the verifier, factory, and preapproval
-- disclosures the buyer needs to reach the full settlement path.
submitFailsWithDiscs : PaidFixture -> Commands a -> Text -> Script ()
submitFailsWithDiscs f cmds = expectAbort
  ( trySubmit
      ( actAs f.buyer
          <> disclose f.verifierDisc
          <> disclose f.factoryDisc
          <> disclose f.preapprovalDisc
      )
      cmds
  )

-- | As `submitFailsWithDiscs`, but for the path that supplies no preapproval, so
-- only the verifier and factory are disclosed.
submitFailsWithDiscsNoPreapproval : PaidFixture -> Commands a -> Text -> Script ()
submitFailsWithDiscsNoPreapproval f cmds = expectAbort
  ( trySubmit
      ( actAs f.buyer
          <> disclose f.verifierDisc
          <> disclose f.factoryDisc
      )
      cmds
  )

-- The producer allows audit records but the caller declines: the quote verifies,
-- the fee settles, and no audit record is written.
testAuditProducerAllowsCallerDeclines : Script ()
testAuditProducerAllowsCallerDeclines = do
  f <- setup                                  -- allowsAuditRecords = True
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload
  verified <- submitPaid f $
    exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
      actor = f.buyer, payload, signature = sig, payment = paymentArgs f, createAuditRecord = False
  verified.quote.feedId === "BTC/USD"
  assertFeeSettled f
  assertNoAuditRecords f.oracle

-- The caller requests an audit record but the producer's policy forbids it: the
-- quote verifies and the fee still settles (payment is independent of the gate),
-- and no audit record is written.
testAuditProducerForbidsCallerRequests : Script ()
testAuditProducerForbidsCallerRequests = do
  f <- setupWith False
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload
  verified <- submitPaid f $
    exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
      actor = f.buyer, payload, signature = sig, payment = paymentArgs f, createAuditRecord = True
  verified.quote.feedId === "BTC/USD"
  assertFeeSettled f
  assertNoAuditRecords f.oracle

-- Neither the producer's policy nor the caller opts in: the quote verifies, the
-- fee settles, and no audit record is written.
testAuditNeitherOptsIn : Script ()
testAuditNeitherOptsIn = do
  f <- setupWith False
  now <- getTime
  let payload = defaultPayload f now
  sig <- signPaid f.keyPair.privateKey payload
  verified <- submitPaid f $
    exerciseCmd f.verifierIf PaidQuoteVerifier_VerifyAndPay with
      actor = f.buyer, payload, signature = sig, payment = paymentArgs f, createAuditRecord = False
  verified.quote.feedId === "BTC/USD"
  assertFeeSettled f
  assertNoAuditRecords f.oracle

-- | Submit `cmds` as the buyer with the verifier, factory, and preapproval
-- disclosures the full settlement path needs.
submitPaid : PaidFixture -> Commands a -> Script a
submitPaid f = submit
  ( actAs f.buyer
      <> disclose f.verifierDisc
      <> disclose f.factoryDisc
      <> disclose f.preapprovalDisc
  )

-- | Assert the treasury holds exactly the one fee holding a settlement credits,
-- proving the fee settled regardless of whether an audit record was written.
assertFeeSettled : PaidFixture -> Script ()
assertFeeSettled f = do
  treasuryHoldings <- query @RegistryHolding f.treasury
  case treasuryHoldings of
    [(_, h)] -> do
      h.owner        === f.treasury
      h.amount       === defaultFee
      h.instrumentId === f.instrumentId
    _ -> abort ("expected exactly one treasury holding, got: " <> show (length treasuryHoldings))

-- | Query the single `AuditRecord` visible to `party`, failing unless there is
-- exactly one. A successful paid verification writes one record, seen by both
-- the verifying party (its observer) and the producer (its signatory).
queryOneAuditRecord : Party -> Script Audit.AuditRecord
queryOneAuditRecord party = do
  records <- query @Audit.AuditRecord party
  case records of
    [(_, r)] -> pure r
    _ -> abort ("expected exactly one audit record, got: " <> show (length records))

-- | Assert the producer (the audit record's signatory) sees no audit record,
-- the state after a paid verification that aborted before writing one.
assertNoAuditRecords : Party -> Script ()
assertNoAuditRecords producer = do
  records <- query @Audit.AuditRecord producer
  assertMsg "no audit record written for a failed verification" (null records)
