-- | Tests for the `DataPointVerifier` interface against real secp256k1 keys, and
-- golden vectors for its `v1-datapoint-tlv` encoder. Each script generates a
-- keypair with `secp256k1generatekeypair`, signs the canonical encoding of a
-- payload with `secp256k1sign`, and exercises `DataPointVerifier_Verify` against
-- a verifier created with the matching public key. Negative cases assert the
-- specific abort message so each failure is shown to be for its intended reason.
-- The verifier-consumer workflow is exercised here too, demonstrating
-- verify-and-use through a disclosed verifier with the schema-aware identity gate.
--
-- The happy path also checks the durable `AuditRecord` the verify choice writes
-- on success: that both the verifying party (its observer) and the producer (its
-- signatory) see one record, and that it carries the verified schema and values
-- and the signature evidence. The failure cases check that an aborted
-- verification writes no record.
--
-- The golden tests are literal `===` assertions on `canonicalDataPointEncode`.
-- They are the encoder's public answer key and a regression lock at once: the
-- expected hex is generated by running the encoder itself, so any change to the
-- encoding trips an assertion rather than silently changing the bytes a producer
-- must reproduce off-ledger.
module Test.DataPointVerifierV1Test where

import DA.Assert ((===))
import DA.Optional (isSome)
import DA.Time (addRelTime, hours)
import qualified DA.TextMap as TM
import Daml.Script

import DataStandard.DataPointVerifierV1
import qualified DataStandard.DataPointVerifierAuditV1 as Audit
import DataStandard.Utils (AnyValue(..), Values, insertField)
import DataPointVerifierProducer.SignatureVerifier
import DataPointVerifierConsumer.Trading
import Test.Fixtures (submitFailsWith)

-- | A keypair, the on-ledger verifier created with its public key, and the
-- disclosure blob a non-stakeholder needs to exercise `DataPointVerifier_Verify`.
data VerifierFixture = VerifierFixture with
    oracle      : Party
    reader      : Party
    keyPair     : Secp256k1KeyPair
    verifierTpl : ContractId DataPointSignatureVerifier
    verifierIf  : ContractId DataPointVerifier
    disc        : Disclosure

-- | Allocate parties, generate a real secp256k1 keypair, publish a verifier
-- holding the public key with audit records allowed, and capture its disclosure.
setup : Script VerifierFixture
setup = setupWith True

-- | As `setup`, publishing the verifier with the given `allowsAuditRecords`
-- policy so a test can pin either side of the audit double gate.
setupWith : Bool -> Script VerifierFixture
setupWith allowsAuditRecords = do
  oracle  <- allocateParty "Oracle"
  reader  <- allocateParty "Reader"
  keyPair <- secp256k1generatekeypair
  verifierTpl <- submit oracle $ createCmd DataPointSignatureVerifier with
    oracle
    publicKey = keyPair.publicKey
    allowsAuditRecords
  Some disc <- queryDisclosure oracle verifierTpl
  pure VerifierFixture with
    oracle, reader, keyPair, verifierTpl, disc
    verifierIf = toInterfaceContractId @DataPointVerifier verifierTpl

-- | The payload of a standard reference-rate data point: a feed identifier and a
-- rate, the shape the consumer example reads.
ratePayload : Text -> Decimal -> Values
ratePayload feedId rate =
  insertField "rate" rate (insertField "feedId" feedId TM.empty)

-- | A standard, valid data point: the EUR/USD reference rate at 1.0875, published
-- now, expiring in 1h, schema "1.0.0".
defaultPayload : Time -> SignedDataPoint
defaultPayload now = SignedDataPoint with
  publishedAt = now
  expiresAt   = addRelTime now (hours 1)
  schemaVersion = "1.0.0"
  values = ratePayload "EUR/USD" 1.0875

-- | Sign a payload's canonical encoding with a private key, producing the same
-- signature the producer would off-ledger. `secp256k1sign` SHA-256s the
-- hex-encoded message internally, matching the on-ledger `secp256k1` check. The
-- encoding is already hex, so unlike the quote codec there is no `toHex` wrapper.
signDataPoint : Text -> SignedDataPoint -> Script Text
signDataPoint privateKey payload =
  secp256k1sign privateKey (canonicalDataPointEncode payload)

-- A valid signature verifies and returns the data point field-aligned with the
-- pushed view, plus the evidence triple.
testVerifyHappyPath : Script ()
testVerifyHappyPath = do
  f <- setup
  now <- getTime
  let payload = defaultPayload now
  sig <- signDataPoint f.keyPair.privateKey payload
  verified <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload, signature = sig
  verified.distributor   === f.oracle
  verified.schemaVersion === "1.0.0"
  verified.values        === payload.values
  verified.publishedAt   === payload.publishedAt
  verified.canonicalHash === dataPointCanonicalHash payload
  verified.signature     === sig
  verified.publicKey      === f.keyPair.publicKey

  -- The verification wrote a durable audit record, seen by the verifying party
  -- (its observer), carrying every field the signature committed to.
  record <- queryOneAuditRecord f.reader
  record.audit.verifier      === f.reader
  record.audit.distributor   === f.oracle
  record.audit.verifiedAt    === now
  record.audit.publishedAt   === payload.publishedAt
  record.audit.expiresAt     === payload.expiresAt
  record.audit.canonicalHash === verified.canonicalHash
  record.audit.signature     === sig
  record.audit.publicKey     === f.keyPair.publicKey
  record.schemaVersion       === payload.schemaVersion
  record.values              === payload.values

  -- The producer sees the same record from the signatory side.
  producerRecord <- queryOneAuditRecord f.oracle
  producerRecord === record

-- A well-formed signature that belongs to a different payload is rejected: it is
-- valid DER but does not match the presented payload, so the secp256k1 check
-- returns false rather than aborting on a malformed argument.
testTamperedSignatureRejected : Script ()
testTamperedSignatureRejected = do
  f <- setup
  now <- getTime
  let payload      = defaultPayload now
      otherPayload = payload with values = ratePayload "GBP/USD" 1.27
  wrongSig <- signDataPoint f.keyPair.privateKey otherPayload
  submitFailsWith f.reader f.disc
    (exerciseCmd f.verifierIf DataPointVerifier_Verify with
      actor = f.reader, payload, signature = wrongSig, createAuditRecord = True)
    "invalid signature"
  assertNoAuditRecords f.oracle

-- A malformed (non-DER) signature is rejected deterministically by the builtin
-- before the signature can be checked, on its own distinct message.
testMalformedSignatureRejected : Script ()
testMalformedSignatureRejected = do
  f <- setup
  now <- getTime
  let payload = defaultPayload now
  submitFailsWith f.reader f.disc
    (exerciseCmd f.verifierIf DataPointVerifier_Verify with
      actor = f.reader, payload, signature = "00bad00signature", createAuditRecord = True)
    "not a DER encoded hex string"

-- A valid signature over one payload does not verify a payload with a mutated
-- value: the signature covers the encoded payload, so tampering invalidates it.
testTamperedPayloadRejected : Script ()
testTamperedPayloadRejected = do
  f <- setup
  now <- getTime
  let payloadA = defaultPayload now
  sigA <- signDataPoint f.keyPair.privateKey payloadA
  let payloadB = payloadA with values = ratePayload "EUR/USD" 9.9999
  submitFailsWith f.reader f.disc
    (exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload = payloadB, signature = sigA)
    "invalid signature"

-- A correctly-signed payload past its expiry is rejected: expiry is the sole
-- replay defence.
testExpiredRejected : Script ()
testExpiredRejected = do
  f <- setup
  now <- getTime
  let payload = defaultPayload now            -- expires now + 1h
  sig <- signDataPoint f.keyPair.privateKey payload
  passTime (hours 2)                          -- move strictly past expiresAt
  submitFailsWith f.reader f.disc
    (exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload, signature = sig)
    "payload expired"
  assertNoAuditRecords f.oracle

-- The boundary instant is accepted: a payload presented exactly at expiresAt
-- still verifies (the check is `now <= expiresAt`).
testExpiryBoundaryAccepted : Script ()
testExpiryBoundaryAccepted = do
  f <- setup
  now <- getTime
  let payload = (defaultPayload now) with expiresAt = now
  sig <- signDataPoint f.keyPair.privateKey payload
  verified <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload, signature = sig
  verified.schemaVersion === "1.0.0"

-- Verifying without disclosing the verifier fails on visibility, before any
-- business check.
testVerifyWithoutDisclosureFails : Script ()
testVerifyWithoutDisclosureFails = do
  f <- setup
  now <- getTime
  let payload = defaultPayload now
  sig <- signDataPoint f.keyPair.privateKey payload
  r <- trySubmit (actAs f.reader)
    (exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload, signature = sig)
  case r of
    Right _ -> abort "expected a visibility failure"
    Left _  -> pure ()

-- The verifier is nonconsuming: it survives a verification and is reusable across
-- payloads.
testVerifierReusable : Script ()
testVerifierReusable = do
  f <- setup
  now <- getTime
  let p1 = defaultPayload now
      p2 = p1 with values = ratePayload "GBP/USD" 1.27
  s1 <- signDataPoint f.keyPair.privateKey p1
  s2 <- signDataPoint f.keyPair.privateKey p2
  _ <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload = p1, signature = s1
  _ <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload = p2, signature = s2
  active <- queryContractId f.oracle f.verifierTpl
  assertMsg "nonconsuming verifier stays active" (isSome active)

-- A key signed by one producer does not verify on a verifier holding a different
-- producer's key. Models key rotation: a payload signed under the new key fails
-- on the old (still-active) verifier.
testWrongKeyRejected : Script ()
testWrongKeyRejected = do
  f <- setup
  now <- getTime
  other <- secp256k1generatekeypair
  let payload = defaultPayload now
  sigOther <- signDataPoint other.privateKey payload
  submitFailsWith f.reader f.disc
    (exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload, signature = sigOther)
    "invalid signature"

-- A payload signed with `publishedAt` after `expiresAt` is rejected by the
-- verifier on the well-formedness check, before the expiry check. The window ends
-- before it begins, so it could never be live; the signature is valid, so this
-- proves the verifier rejects the ill-formed window itself.
testPublishedAfterExpiryRejected : Script ()
testPublishedAfterExpiryRejected = do
  f <- setup
  now <- getTime
  let payload = (defaultPayload now) with
        publishedAt = addRelTime now (hours 2)
        expiresAt   = addRelTime now (hours 1)
  sig <- signDataPoint f.keyPair.privateKey payload
  submitFailsWith f.reader f.disc
    (exerciseCmd f.verifierIf DataPointVerifier_Verify with
      actor = f.reader, payload, signature = sig, createAuditRecord = True)
    "published after expiry"

-- A payload whose free text carries the bytes the quote codec reserved as a
-- field delimiter ("|") and bytes that look like an embedded length prefix still
-- verifies: the TLV is length-prefixed, so free text never shifts a field
-- boundary and needs no delimiter guard. This is the deliberate cleanup over the
-- quote codec, asserted directly.
testFreeTextInValuesVerifies : Script ()
testFreeTextInValuesVerifies = do
  f <- setup
  now <- getTime
  let payload = (defaultPayload now) with
        values = ratePayload "BTC|USD|0000000bnot-a-length" 65000.0
  sig <- signDataPoint f.keyPair.privateKey payload
  verified <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd f.verifierIf DataPointVerifier_Verify with createAuditRecord = True, actor = f.reader, payload, signature = sig
  verified.values === payload.values

-- End-to-end verify-and-use: the consumer workflow authenticates a signed data
-- point through a disclosed verifier and records the rate, gating on schema and
-- in-payload feed identity.
testConsumerWorkflowHappyPath : Script ()
testConsumerWorkflowHappyPath = do
  f <- setup
  now <- getTime
  let payload = defaultPayload now
  sig <- signDataPoint f.keyPair.privateKey payload
  sub <- submit f.reader $ createCmd RateSubscription with
    subscriber = f.reader, expectedDistributor = f.oracle
    expectedSchemaVersion = "1.0.0", expectedFeedId = "EUR/USD"
    maxAge = hours 24, verifierCid = f.verifierIf
  recordedCid <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd sub RecordSignedRate with payload, signature = sig
  Some r <- queryContractId f.reader recordedCid
  r.feedId        === "EUR/USD"
  r.rate          === 1.0875
  r.distributor   === f.oracle
  r.schemaVersion === "1.0.0"

-- The consumer rejects a verified data point whose in-payload feed id is not the
-- one subscribed to; the standard authenticates the signer, not the feed.
testConsumerWrongFeedRejected : Script ()
testConsumerWrongFeedRejected = do
  f <- setup
  now <- getTime
  let payload = defaultPayload now            -- feedId = EUR/USD
  sig <- signDataPoint f.keyPair.privateKey payload
  sub <- submit f.reader $ createCmd RateSubscription with
    subscriber = f.reader, expectedDistributor = f.oracle
    expectedSchemaVersion = "1.0.0", expectedFeedId = "GBP/USD"
    maxAge = hours 24, verifierCid = f.verifierIf
  submitFailsWith f.reader f.disc
    (exerciseCmd sub RecordSignedRate with payload, signature = sig)
    "feed mismatch"

-- The consumer rejects a verified data point whose schema is not the one it knows
-- how to read, before it tries to read the feed id.
testConsumerWrongSchemaRejected : Script ()
testConsumerWrongSchemaRejected = do
  f <- setup
  now <- getTime
  let payload = (defaultPayload now) with schemaVersion = "2.0.0"
  sig <- signDataPoint f.keyPair.privateKey payload
  sub <- submit f.reader $ createCmd RateSubscription with
    subscriber = f.reader, expectedDistributor = f.oracle
    expectedSchemaVersion = "1.0.0", expectedFeedId = "EUR/USD"
    maxAge = hours 24, verifierCid = f.verifierIf
  submitFailsWith f.reader f.disc
    (exerciseCmd sub RecordSignedRate with payload, signature = sig)
    "unexpected schema version"

-- The consumer rejects a verified data point from a distributor other than the
-- one the subscription pins. The signature verifies against the real oracle key,
-- so the data point is authentic; the distributor gate, not the verifier, is what
-- stops it.
testConsumerUntrustedDistributorRejected : Script ()
testConsumerUntrustedDistributorRejected = do
  f <- setup
  other <- allocateParty "OtherOracle"
  now <- getTime
  let payload = defaultPayload now
  sig <- signDataPoint f.keyPair.privateKey payload
  sub <- submit f.reader $ createCmd RateSubscription with
    subscriber = f.reader, expectedDistributor = other
    expectedSchemaVersion = "1.0.0", expectedFeedId = "EUR/USD"
    maxAge = hours 24, verifierCid = f.verifierIf
  submitFailsWith f.reader f.disc
    (exerciseCmd sub RecordSignedRate with payload, signature = sig)
    "untrusted distributor"

-- The consumer rejects a verified data point older than its staleness bound. The
-- payload was produced two hours ago but still has a live window, so it verifies
-- and the consumer's own `maxAge` of one hour is what rejects it.
testConsumerStaleRejected : Script ()
testConsumerStaleRejected = do
  f <- setup
  now <- getTime
  let payload = (defaultPayload now) with publishedAt = addRelTime now (hours (-2))
  sig <- signDataPoint f.keyPair.privateKey payload
  sub <- submit f.reader $ createCmd RateSubscription with
    subscriber = f.reader, expectedDistributor = f.oracle
    expectedSchemaVersion = "1.0.0", expectedFeedId = "EUR/USD"
    maxAge = hours 1, verifierCid = f.verifierIf
  submitFailsWith f.reader f.disc
    (exerciseCmd sub RecordSignedRate with payload, signature = sig)
    "data point too stale"

-- The consumer rejects a verified data point stamped in the future. The payload
-- has a live window, so it verifies, but its publishedAt is ahead of now, which
-- the consumer's staleness gate must reject rather than read as freshly published.
testConsumerFutureDatedRejected : Script ()
testConsumerFutureDatedRejected = do
  f <- setup
  now <- getTime
  let payload = (defaultPayload now) with
        publishedAt = addRelTime now (hours 2)
        expiresAt   = addRelTime now (hours 3)
  sig <- signDataPoint f.keyPair.privateKey payload
  sub <- submit f.reader $ createCmd RateSubscription with
    subscriber = f.reader, expectedDistributor = f.oracle
    expectedSchemaVersion = "1.0.0", expectedFeedId = "EUR/USD"
    maxAge = hours 24, verifierCid = f.verifierIf
  submitFailsWith f.reader f.disc
    (exerciseCmd sub RecordSignedRate with payload, signature = sig)
    "data point published in the future"

-- | A payload with one of each scalar, including a negative `Int` and a negative
-- `Decimal`, used as a golden vector. The keys are chosen to be in a non-obvious
-- insertion order so the sorted-key encoding is exercised.
flatScalarPayload : SignedDataPoint
flatScalarPayload = SignedDataPoint with
  publishedAt = epoch
  expiresAt   = epoch
  schemaVersion = "g"
  values = TM.fromList
    [ ("t", AVText "hi")
    , ("b", AVBool True)
    , ("i", AVInt (-5))
    , ("d", AVDecimal (-12.5))
    , ("w", AVTime epoch)
    ]

-- | A nested list-of-maps payload (an index-constituents shape) used as a golden
-- vector: a list whose elements are maps, exercising the recursive list and map
-- paths together.
nestedListPayload : SignedDataPoint
nestedListPayload = SignedDataPoint with
  publishedAt = epoch
  expiresAt   = epoch
  schemaVersion = "g"
  values = TM.fromList
    [ ("constituents", AVList
        [ AVMap (TM.fromList [("symbol", AVText "AAA"), ("weight", AVDecimal 0.6)])
        , AVMap (TM.fromList [("symbol", AVText "BBB"), ("weight", AVDecimal 0.4)])
        ])
    ]

-- | A payload whose map keys include an astral-plane (four-UTF-8-byte) character
-- alongside ASCII keys, used as a golden vector to lock the key sort order. If
-- `DA.TextMap.toList` ordered keys by UTF-16 code unit rather than code point, an
-- astral key would sort before BMP keys in the 0xE000-0xFFFF range and change the
-- bytes; the fixed literal catches any such drift.
astralKeyPayload : SignedDataPoint
astralKeyPayload = SignedDataPoint with
  publishedAt = epoch
  expiresAt   = epoch
  schemaVersion = "g"
  values = TM.fromList
    [ ("z", AVInt 1)
    , ("\x1F600", AVInt 2)        -- U+1F600, astral plane, four UTF-8 bytes
    , ("\xE000", AVInt 3)         -- U+E000, BMP private use
    ]

-- | A pair of keys where one is a prefix of the other, used as a golden vector to
-- lock shorter-prefix-first ordering ("a" before "ab"), the Git base_name_compare
-- corner.
prefixPairPayload : SignedDataPoint
prefixPairPayload = SignedDataPoint with
  publishedAt = epoch
  expiresAt   = epoch
  schemaVersion = "g"
  values = TM.fromList
    [ ("ab", AVInt 2)
    , ("a", AVInt 1)
    ]

-- | An empty list as a single payload value, used to show an empty list and an
-- empty map do not encode the same.
emptyListPayload : SignedDataPoint
emptyListPayload = SignedDataPoint with
  publishedAt = epoch
  expiresAt   = epoch
  schemaVersion = "g"
  values = TM.fromList [("x", AVList [])]

-- | An empty map as a single payload value, the companion to `emptyListPayload`.
emptyMapPayload : SignedDataPoint
emptyMapPayload = SignedDataPoint with
  publishedAt = epoch
  expiresAt   = epoch
  schemaVersion = "g"
  values = TM.fromList [("x", AVMap TM.empty)]

-- The fixed-width big-endian integer helper renders zero, a negative value, and
-- a value that borrows across a byte boundary as two's-complement, eight bytes.
-- The byte string an off-ledger encoder must reproduce for an `Int` or a `Time`.
testGoldenIntToBEHex : Script ()
testGoldenIntToBEHex = do
  intToBEHex 8 0      === "0000000000000000"
  intToBEHex 8 (-5)   === "fffffffffffffffb"
  intToBEHex 8 (-256) === "ffffffffffffff00"
  intToBEHex 8 1      === "0000000000000001"
  count4 3            === "00000003"

-- A flat map with one of each scalar, including a negative `Int` and a negative
-- `Decimal`. Locks the scalar tag bytes (0x01-0x07), the eight-byte two's-
-- complement `Int`, the text-rendered `Decimal`, the millisecond `Time`, and the
-- ascending key order (b, d, i, t, w).
testGoldenFlatScalars : Script ()
testGoldenFlatScalars =
  canonicalDataPointEncode flatScalarPayload ===
    "0000000000000000000000000000000000000001670b0000000500000001620101000000016403000000052d31322e35000000016902fffffffffffffffb0000000174070000000268690000000177040000000000000000"

-- A decimal with an integral value still renders with a fractional part: `show`
-- emits "1.0", not "1", so the encoding keeps at least one fractional digit. The
-- bytes are the value tag 0x03, a four-byte length of 3, then "1.0". Locks that
-- rule, which the fractional-value vectors above do not exercise.
testGoldenIntegerDecimal : Script ()
testGoldenIntegerDecimal =
  encodeAnyValue (AVDecimal 1.0) === "0300000003312e30"

-- An index-constituents shape: a single field holding a list of maps. Locks the
-- recursive list and map paths nesting together.
testGoldenNestedList : Script ()
testGoldenNestedList =
  canonicalDataPointEncode nestedListPayload ===
    "0000000000000000000000000000000000000001670b000000010000000c636f6e7374697475656e74730a000000020b000000020000000673796d626f6c0700000003414141000000067765696768740300000003302e360b000000020000000673796d626f6c0700000003424242000000067765696768740300000003302e34"

-- Map keys including an astral-plane character (U+1F600, four UTF-8 bytes) and a
-- BMP private-use character (U+E000, three UTF-8 bytes) alongside ASCII. Locks the
-- sort as raw UTF-8 byte order: z (0x7a), then U+E000 (0xee8080), then U+1F600
-- (0xf09f9880). UTF-16 order would place the astral character before U+E000 and
-- change the bytes, so this vector proves `DA.TextMap.toList` sorts by code point,
-- which coincides with UTF-8 byte order.
testGoldenAstralKeys : Script ()
testGoldenAstralKeys =
  canonicalDataPointEncode astralKeyPayload ===
    "0000000000000000000000000000000000000001670b00000003000000017a02000000000000000100000003ee808002000000000000000300000004f09f9880020000000000000002"

-- A prefix pair of keys ("a" and "ab"). Locks shorter-prefix-first ordering: "a"
-- (0x61) sorts before "ab" (0x6162), the Git base_name_compare corner.
testGoldenPrefixPair : Script ()
testGoldenPrefixPair =
  canonicalDataPointEncode prefixPairPayload ===
    "0000000000000000000000000000000000000001670b000000020000000161020000000000000001000000026162020000000000000002"

-- An empty list and an empty map under the same key do not encode the same: they
-- differ in the value's type tag (0x0a list versus 0x0b map), each followed by a
-- zero count. Locks that the type tag distinguishes empty containers.
testGoldenEmptyContainersDiffer : Script ()
testGoldenEmptyContainersDiffer = do
  let encList = canonicalDataPointEncode emptyListPayload
      encMap  = canonicalDataPointEncode emptyMapPayload
  encList === "0000000000000000000000000000000000000001670b0000000100000001780a00000000"
  encMap  === "0000000000000000000000000000000000000001670b0000000100000001780b00000000"
  assertMsg "empty list and empty map must encode differently" (encList /= encMap)

-- The producer allows audit records but the caller declines: the data point
-- still verifies and no audit record is written.
testAuditProducerAllowsCallerDeclines : Script ()
testAuditProducerAllowsCallerDeclines = do
  f <- setup                                  -- allowsAuditRecords = True
  now <- getTime
  let payload = defaultPayload now
  sig <- signDataPoint f.keyPair.privateKey payload
  verified <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd f.verifierIf DataPointVerifier_Verify with
      actor = f.reader, payload, signature = sig, createAuditRecord = False
  verified.schemaVersion === "1.0.0"
  assertNoAuditRecords f.oracle

-- The caller requests an audit record but the producer's policy forbids it: the
-- data point still verifies and no audit record is written.
testAuditProducerForbidsCallerRequests : Script ()
testAuditProducerForbidsCallerRequests = do
  f <- setupWith False
  now <- getTime
  let payload = defaultPayload now
  sig <- signDataPoint f.keyPair.privateKey payload
  verified <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd f.verifierIf DataPointVerifier_Verify with
      actor = f.reader, payload, signature = sig, createAuditRecord = True
  verified.schemaVersion === "1.0.0"
  assertNoAuditRecords f.oracle

-- Neither the producer's policy nor the caller opts in: the data point still
-- verifies and no audit record is written.
testAuditNeitherOptsIn : Script ()
testAuditNeitherOptsIn = do
  f <- setupWith False
  now <- getTime
  let payload = defaultPayload now
  sig <- signDataPoint f.keyPair.privateKey payload
  verified <- submit (actAs f.reader <> disclose f.disc) $
    exerciseCmd f.verifierIf DataPointVerifier_Verify with
      actor = f.reader, payload, signature = sig, createAuditRecord = False
  verified.schemaVersion === "1.0.0"
  assertNoAuditRecords f.oracle

-- | Query the single `AuditRecord` visible to `party`, failing unless there is
-- exactly one. A successful verification writes one record, seen by both the
-- verifying party (its observer) and the producer (its signatory).
queryOneAuditRecord : Party -> Script Audit.AuditRecord
queryOneAuditRecord party = do
  records <- query @Audit.AuditRecord party
  case records of
    [(_, r)] -> pure r
    _ -> abort ("expected exactly one audit record, got: " <> show (length records))

-- | Assert the producer (the audit record's signatory) sees no audit record,
-- the state after a verification that aborted before writing one.
assertNoAuditRecords : Party -> Script ()
assertNoAuditRecords producer = do
  records <- query @Audit.AuditRecord producer
  assertMsg "no audit record written for a failed verification" (null records)
