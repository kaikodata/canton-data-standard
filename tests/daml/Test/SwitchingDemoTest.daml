-- | The provider-switching demonstration: one consumer reads the same feed
-- from two structurally different providers with no Daml change. The direct
-- provider stores a price; the market-maker provider stores a bid and an ask
-- and derives the mid. Both expose the identical interface views, so the same
-- compiled consumer choices settle against either, and switching provider is
-- passing a different `expectedDistributor`.
module Test.SwitchingDemoTest where

import DA.Assert ((===))
import Daml.Script

import SwitchingConsumer.Trading
import SwitchingProviderDirect.Oracle
import SwitchingProviderMarketMaker.Oracle
import DataStandard.DataPointV1 (PublishedData)
import DataStandard.QuoteV1 (PublishedQuote)
import DataStandard.Utils (emptyMetadata)
import Test.Fixtures

-- | Both providers publish the same feed at the same price (the market maker's
-- bid/ask straddle it), and the one `QuoteSwitchOffer` choice settles against
-- each in turn. Switching provider is re-pointing `expectedDistributor`.
testQuoteSwitchAcrossProviders : Script ()
testQuoteSwitchAcrossProviders = do
  oracleDirect <- allocateParty "OracleDirect"
  oracleMM     <- allocateParty "OracleMarketMaker"
  seller       <- allocateParty "Seller"
  buyer        <- allocateParty "Buyer"
  now          <- getTime

  directCid <- submit oracleDirect $ createCmd DirectQuote with
    oracle = oracleDirect, feedId = "BTC/USD", assetPair = "BTC/USD"
    price = 65000.0, priceTime = now, publishedAt = now
  mmCid <- submit oracleMM $ createCmd MarketMakerQuote with
    oracle = oracleMM, feedId = "BTC/USD", assetPair = "BTC/USD"
    bid = 64999.0, ask = 65001.0, priceTime = now, publishedAt = now

  -- The same consumer choice handles the direct provider ...
  directOfferCid <- submit seller $ createCmd QuoteSwitchOffer with
    seller, buyer, expectedDistributor = oracleDirect, feedId = "BTC/USD"
    quantity = 0.5
    quoteCid = toInterfaceContractId @PublishedQuote directCid
  Some directDisc <- queryDisclosure oracleDirect directCid
  directSettleCid <- submit (actAs buyer <> disclose directDisc) $
    exerciseCmd directOfferCid AcceptQuoteSwitch
  Some directSettle <- queryContractId buyer directSettleCid
  directSettle.price       === 65000.0
  directSettle.distributor === oracleDirect

  -- ... and the market maker, unchanged.
  mmOfferCid <- submit seller $ createCmd QuoteSwitchOffer with
    seller, buyer, expectedDistributor = oracleMM, feedId = "BTC/USD"
    quantity = 0.5
    quoteCid = toInterfaceContractId @PublishedQuote mmCid
  Some mmDisc <- queryDisclosure oracleMM mmCid
  mmSettleCid <- submit (actAs buyer <> disclose mmDisc) $
    exerciseCmd mmOfferCid AcceptQuoteSwitch
  Some mmSettle <- queryContractId buyer mmSettleCid
  mmSettle.price       === 65000.0
  mmSettle.distributor === oracleMM

-- | The same switch over the generic data point path. The market maker's view
-- carries extra `bid`/`ask` fields, which a consumer reading only `assetPair`
-- and `price` ignores, so both providers settle identically.
testDataPointSwitchAcrossProviders : Script ()
testDataPointSwitchAcrossProviders = do
  oracleDirect <- allocateParty "OracleDirect"
  oracleMM     <- allocateParty "OracleMarketMaker"
  seller       <- allocateParty "Seller"
  buyer        <- allocateParty "Buyer"
  now          <- getTime

  directCid <- submit oracleDirect $ createCmd DirectQuote with
    oracle = oracleDirect, feedId = "BTC/USD", assetPair = "BTC/USD"
    price = 65000.0, priceTime = now, publishedAt = now
  mmCid <- submit oracleMM $ createCmd MarketMakerQuote with
    oracle = oracleMM, feedId = "BTC/USD", assetPair = "BTC/USD"
    bid = 64999.0, ask = 65001.0, priceTime = now, publishedAt = now

  directOfferCid <- submit seller $ createCmd DataPointSwitchOffer with
    seller, buyer, expectedDistributor = oracleDirect, assetPair = "BTC/USD"
    quantity = 0.5
    dataCid = toInterfaceContractId @PublishedData directCid
  Some directDisc <- queryDisclosure oracleDirect directCid
  directSettleCid <- submit (actAs buyer <> disclose directDisc) $
    exerciseCmd directOfferCid AcceptDataPointSwitch
  Some directSettle <- queryContractId buyer directSettleCid
  directSettle.price       === 65000.0
  directSettle.distributor === oracleDirect

  mmOfferCid <- submit seller $ createCmd DataPointSwitchOffer with
    seller, buyer, expectedDistributor = oracleMM, assetPair = "BTC/USD"
    quantity = 0.5
    dataCid = toInterfaceContractId @PublishedData mmCid
  Some mmDisc <- queryDisclosure oracleMM mmCid
  mmSettleCid <- submit (actAs buyer <> disclose mmDisc) $
    exerciseCmd mmOfferCid AcceptDataPointSwitch
  Some mmSettle <- queryContractId buyer mmSettleCid
  mmSettle.price       === 65000.0
  mmSettle.distributor === oracleMM

-- | An offer that trusts `oracleDirect` but is handed the market maker's quote
-- aborts: the standard authenticates the distributor, and the consumer gates on
-- the one it trusts.
testRejectsUntrustedDistributor : Script ()
testRejectsUntrustedDistributor = do
  oracleDirect <- allocateParty "OracleDirect"
  oracleMM     <- allocateParty "OracleMarketMaker"
  seller       <- allocateParty "Seller"
  buyer        <- allocateParty "Buyer"
  now          <- getTime

  mmCid <- submit oracleMM $ createCmd MarketMakerQuote with
    oracle = oracleMM, feedId = "BTC/USD", assetPair = "BTC/USD"
    bid = 64999.0, ask = 65001.0, priceTime = now, publishedAt = now
  offerCid <- submit seller $ createCmd QuoteSwitchOffer with
    seller, buyer, expectedDistributor = oracleDirect, feedId = "BTC/USD"
    quantity = 0.5
    quoteCid = toInterfaceContractId @PublishedQuote mmCid
  Some disc <- queryDisclosure oracleMM mmCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptQuoteSwitch)
    "untrusted distributor"

-- | A trusted distributor publishing a schema without an `assetPair` field
-- aborts the data point path on the missing field. `TestFeed` is a valid
-- `PublishedData` implementation carrying `feedId`/`rate`, not `assetPair`.
testDataPointSwitchRejectsForeignSchema : Script ()
testDataPointSwitchRejectsForeignSchema = do
  oracle <- allocateParty "OracleDirect"
  seller <- allocateParty "Seller"
  buyer  <- allocateParty "Buyer"
  now    <- getTime

  feedCid <- submit oracle $ createCmd TestFeed with
    oracle, subscriber = oracle, feedId = "eurc-usd", rate = 1.0432, at = now
    meta = emptyMetadata
  offerCid <- submit seller $ createCmd DataPointSwitchOffer with
    seller, buyer, expectedDistributor = oracle, assetPair = "BTC/USD"
    quantity = 0.5
    dataCid = toInterfaceContractId @PublishedData feedCid
  Some disc <- queryDisclosure oracle feedCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptDataPointSwitch)
    "published data missing field: assetPair"

-- | When two trusted providers agree within tolerance, the cross-check settles
-- at the average of their prices.
testCrossCheckSettlesWhenProvidersAgree : Script ()
testCrossCheckSettlesWhenProvidersAgree = do
  oracleDirect <- allocateParty "OracleDirect"
  oracleMM     <- allocateParty "OracleMarketMaker"
  seller       <- allocateParty "Seller"
  buyer        <- allocateParty "Buyer"
  now          <- getTime

  directCid <- submit oracleDirect $ createCmd DirectQuote with
    oracle = oracleDirect, feedId = "BTC/USD", assetPair = "BTC/USD"
    price = 65000.0, priceTime = now, publishedAt = now
  -- Mid of 64998/65006 is 65002, ten dollars above the direct provider.
  mmCid <- submit oracleMM $ createCmd MarketMakerQuote with
    oracle = oracleMM, feedId = "BTC/USD", assetPair = "BTC/USD"
    bid = 64998.0, ask = 65006.0, priceTime = now, publishedAt = now

  offerCid <- submit seller $ createCmd CrossCheckOffer with
    seller, buyer
    expectedDistributorA = oracleDirect, expectedDistributorB = oracleMM
    feedId = "BTC/USD", quantity = 0.5, tolerance = 50.0
    quoteCidA = toInterfaceContractId @PublishedQuote directCid
    quoteCidB = toInterfaceContractId @PublishedQuote mmCid
  Some discA <- queryDisclosure oracleDirect directCid
  Some discB <- queryDisclosure oracleMM mmCid
  settleCid <- submit (actAs buyer <> disclose discA <> disclose discB) $
    exerciseCmd offerCid AcceptCrossCheck
  Some s <- queryContractId buyer settleCid
  s.price          === 65001.0
  s.distributorA   === oracleDirect
  s.distributorB   === oracleMM

-- | When two providers disagree beyond tolerance, the cross-check aborts rather
-- than settle on a contested price.
testCrossCheckRejectsWhenProvidersDisagree : Script ()
testCrossCheckRejectsWhenProvidersDisagree = do
  oracleDirect <- allocateParty "OracleDirect"
  oracleMM     <- allocateParty "OracleMarketMaker"
  seller       <- allocateParty "Seller"
  buyer        <- allocateParty "Buyer"
  now          <- getTime

  directCid <- submit oracleDirect $ createCmd DirectQuote with
    oracle = oracleDirect, feedId = "BTC/USD", assetPair = "BTC/USD"
    price = 65000.0, priceTime = now, publishedAt = now
  -- Mid of 69999/70001 is 70000, five thousand above the direct provider.
  mmCid <- submit oracleMM $ createCmd MarketMakerQuote with
    oracle = oracleMM, feedId = "BTC/USD", assetPair = "BTC/USD"
    bid = 69999.0, ask = 70001.0, priceTime = now, publishedAt = now

  offerCid <- submit seller $ createCmd CrossCheckOffer with
    seller, buyer
    expectedDistributorA = oracleDirect, expectedDistributorB = oracleMM
    feedId = "BTC/USD", quantity = 0.5, tolerance = 50.0
    quoteCidA = toInterfaceContractId @PublishedQuote directCid
    quoteCidB = toInterfaceContractId @PublishedQuote mmCid
  Some discA <- queryDisclosure oracleDirect directCid
  Some discB <- queryDisclosure oracleMM mmCid
  expectAbort
    (trySubmit (actAs buyer <> disclose discA <> disclose discB)
       (exerciseCmd offerCid AcceptCrossCheck))
    "providers disagree beyond tolerance"
