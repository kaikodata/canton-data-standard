-- | Shared fixtures and assertion helpers for the test suite.
module Test.Fixtures where

import qualified DA.Text as T
import qualified DA.TextMap as TM
import Daml.Script

import DataStandard.DataPointV1
import DataStandard.QuoteV1
import DataStandard.Utils

-- | A minimal `PublishedData` implementation, just enough to exercise the
-- interface. The full example templates live in `examples/`.
template TestFeed
  with
    oracle     : Party
    subscriber : Party
    feedId     : Text
    rate       : Decimal
    at         : Time
    meta       : Metadata
  where
    signatory oracle
    observer subscriber

    interface instance PublishedData for TestFeed where
      view = PublishedDataView with
        distributor   = oracle
        publishedAt   = at
        schemaVersion = "1.0.0"
        values        = TM.fromList
          [ ("feedId", AVText feedId)
          , ("rate",   AVDecimal rate)
          ]
        metadata      = meta

-- | A minimal `PublishedQuote` implementation, just enough to exercise the
-- interface. The full example templates live in `examples/`.
template TestQuote
  with
    oracle     : Party
    subscriber : Party
    feedId     : Text
    price      : Decimal
    priceTime  : Time
    publishedAt : Time
    meta       : Metadata
  where
    signatory oracle
    observer subscriber

    interface instance PublishedQuote for TestQuote where
      view = PublishedQuoteView with
        distributor = oracle
        quote = Quote with
          feedId
          price
          priceTime
        publishedAt
        metadata = meta

-- | Expect the submission to abort with a message containing `needle`.
-- Asserting the specific message proves the scenario fails for the intended
-- reason, not an incidental visibility or authorization error.
submitFailsWith : Party -> Disclosure -> Commands a -> Text -> Script ()
submitFailsWith p d cmds = expectAbort (trySubmit (actAs p <> disclose d) cmds)

-- | As `submitFailsWith`, but for submissions that attach no disclosed
-- contract.
submitFailsWithNoDisclosure : Party -> Commands a -> Text -> Script ()
submitFailsWithNoDisclosure p cmds = expectAbort (trySubmit p cmds)

-- | Run a submission, fail the test unless it aborted, and require the abort
-- message to contain `needle`.
expectAbort : Script (Either SubmitError a) -> Text -> Script ()
expectAbort run needle = do
  r <- run
  case r of
    Right _ -> abort ("expected failure containing: " <> needle)
    Left e ->
      let shown = show e
      in assertMsg ("wanted error containing '" <> needle <> "', got: " <> shown)
           (needle `T.isInfixOf` shown)

-- | Expect the submission to fail with a `SubmitError` that satisfies
-- `matches`, rather than with a particular error-message substring. Platform
-- error text can vary across ledger versions, so the negative tests in this
-- live-capable suite discriminate on the structured error constructor; the
-- standard's own `assertMsg` messages are matched by text elsewhere, since
-- those are fixed by this repository.
submitFailsMatching : Party -> Disclosure -> Commands a -> (SubmitError -> Bool) -> Text -> Script ()
submitFailsMatching p d cmds = expectFailure (trySubmit (actAs p <> disclose d) cmds)

-- | As `submitFailsMatching`, but for submissions that attach no disclosed
-- contract.
submitFailsMatchingNoDisclosure : Party -> Commands a -> (SubmitError -> Bool) -> Text -> Script ()
submitFailsMatchingNoDisclosure p cmds = expectFailure (trySubmit p cmds)

-- | Run a submission, fail the test unless it aborted, and require the
-- resulting `SubmitError` to satisfy `matches`. `expected` names the failure
-- for the diagnostic shown when a different error surfaces instead.
expectFailure : Script (Either SubmitError a) -> (SubmitError -> Bool) -> Text -> Script ()
expectFailure run matches expected = do
  r <- run
  case r of
    Right _ -> abort ("expected failure: " <> expected)
    Left e -> assertMsg ("expected " <> expected <> ", got: " <> show e) (matches e)

-- | The submission lacked the authority a choice required, for example acting
-- as a party that is not the choice's controller.
isAuthorizationFailure : SubmitError -> Bool
isAuthorizationFailure AuthorizationError{} = True
isAuthorizationFailure _ = False

-- | A referenced contract id did not resolve to a contract the submitter can
-- use: either it was never visible to that party (no stakeholder relationship
-- and no disclosure) or an archive-and-replace refresh superseded it before the
-- party read it. The ledger reports both as a not-found contract.
isContractNotFound : SubmitError -> Bool
isContractNotFound ContractNotFound{} = True
isContractNotFound _ = False
