-- | End-to-end tests over the reference producer and consumer, exercising the
-- standard the way an external implementer would.
module Test.ExamplesTest where

import DA.Assert ((===))
import DA.Optional (isNone)
import DA.Time (addRelTime, hours, minutes)
import Daml.Script

import DataConsumer.Trading
import DataProducer.PriceOracle
import QuoteConsumer.Trading
import QuoteProducer.PriceOracle
import DataStandard.DataPointV1 (PublishedData)
import DataStandard.QuoteV1 (PublishedQuote)
import DataStandard.Utils (emptyMetadata)
import Test.Fixtures

testConsumerTradesOffProducersPrice : Script ()
testConsumerTradesOffProducersPrice = do
  oracle <- allocateParty "ExampleOracle"
  seller <- allocateParty "Seller"
  buyer  <- allocateParty "Buyer"
  now    <- getTime
  priceCid <- submit oracle $ createCmd PublishedPrice with
    oracle, assetPair = "BTC/USD", price = 65000.0, at = now
  offerCid <- submit seller $ createCmd TradeOffer with
    seller, buyer, assetPair = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    priceDataCid = toInterfaceContractId @PublishedData priceCid
  Some disc <- queryDisclosure oracle priceCid
  settlementCid <- submit (actAs buyer <> disclose disc) $
    exerciseCmd offerCid AcceptTrade
  Some s <- queryContractId buyer settlementCid
  s.price       === 65000.0
  s.totalAmount === 32500.0
  s.distributor === oracle

testConsumerRejectsWrongAssetPair : Script ()
testConsumerRejectsWrongAssetPair = do
  oracle <- allocateParty "ExampleOracle"
  seller <- allocateParty "Seller"
  buyer  <- allocateParty "Buyer"
  now    <- getTime
  priceCid <- submit oracle $ createCmd PublishedPrice with
    oracle, assetPair = "ETH/USD", price = 3200.0, at = now
  offerCid <- submit seller $ createCmd TradeOffer with
    seller, buyer, assetPair = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    priceDataCid = toInterfaceContractId @PublishedData priceCid
  Some disc <- queryDisclosure oracle priceCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptTrade) "asset pair mismatch"

testUpdateRequiresIncreasingTime : Script ()
testUpdateRequiresIncreasingTime = do
  oracle <- allocateParty "ExampleOracle"
  now    <- getTime
  priceCid <- submit oracle $ createCmd PublishedPrice with
    oracle, assetPair = "BTC/USD", price = 65000.0, at = now
  submitFailsWithNoDisclosure oracle
    (exerciseCmd priceCid UpdatePrice with newPrice = 66000.0, newAt = now)
    "publication time must increase"

-- TestFeed is a valid PublishedData implementation with a different schema:
-- it carries no "assetPair" field.
testConsumerRejectsForeignSchema : Script ()
testConsumerRejectsForeignSchema = do
  oracle <- allocateParty "ExampleOracle"
  seller <- allocateParty "Seller"
  buyer  <- allocateParty "Buyer"
  now    <- getTime
  feedCid <- submit oracle $ createCmd TestFeed with
    oracle, subscriber = oracle, feedId = "eurc-usd", rate = 1.0432, at = now
    meta = emptyMetadata
  offerCid <- submit seller $ createCmd TradeOffer with
    seller, buyer, assetPair = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    priceDataCid = toInterfaceContractId @PublishedData feedCid
  Some disc <- queryDisclosure oracle feedCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptTrade)
    "published data missing field: assetPair"

testProducerUpdatesPrice : Script ()
testProducerUpdatesPrice = do
  oracle <- allocateParty "ExampleOracle"
  now    <- getTime
  priceCid <- submit oracle $ createCmd PublishedPrice with
    oracle, assetPair = "BTC/USD", price = 65000.0, at = now
  newCid <- submit oracle $ exerciseCmd priceCid UpdatePrice with
    newPrice = 66000.0, newAt = addRelTime now (minutes 1)
  old <- queryContractId oracle priceCid
  assertMsg "stale publication must be archived" (isNone old)
  Some v <- queryInterfaceContractId oracle
    (toInterfaceContractId @PublishedData newCid)
  v.publishedAt === addRelTime now (minutes 1)

-- An offer snapshots a specific contract id, so a producer refresh archives
-- it and the late accept fails outright instead of trading on stale data.
testAcceptFailsAfterPriceRefresh : Script ()
testAcceptFailsAfterPriceRefresh = do
  oracle <- allocateParty "ExampleOracle"
  seller <- allocateParty "Seller"
  buyer  <- allocateParty "Buyer"
  now    <- getTime
  priceCid <- submit oracle $ createCmd PublishedPrice with
    oracle, assetPair = "BTC/USD", price = 65000.0, at = now
  offerCid <- submit seller $ createCmd TradeOffer with
    seller, buyer, assetPair = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    priceDataCid = toInterfaceContractId @PublishedData priceCid
  Some disc <- queryDisclosure oracle priceCid
  _ <- submit oracle $ exerciseCmd priceCid UpdatePrice with
    newPrice = 66000.0, newAt = addRelTime now (minutes 1)
  submitFailsMatching buyer disc (exerciseCmd offerCid AcceptTrade)
    isContractNotFound "the refreshed publication's old contract id is gone"

testConsumerTradesOffProducersQuote : Script ()
testConsumerTradesOffProducersQuote = do
  oracle <- allocateParty "ExampleOracle"
  seller <- allocateParty "Seller"
  buyer  <- allocateParty "Buyer"
  now    <- getTime
  let observedAt = addRelTime now (minutes (-1))
  quoteCid <- submit oracle $ createCmd PriceQuote with
    oracle, feedId = "BTC/USD", price = 65000.0, priceTime = observedAt, publishedAt = now
  offerCid <- submit seller $ createCmd QuoteTradeOffer with
    seller, buyer, feedId = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    quoteCid = toInterfaceContractId @PublishedQuote quoteCid
  Some disc <- queryDisclosure oracle quoteCid
  settlementCid <- submit (actAs buyer <> disclose disc) $
    exerciseCmd offerCid AcceptQuoteTrade
  Some s <- queryContractId buyer settlementCid
  s.price       === 65000.0
  s.totalAmount === 32500.0
  s.distributor === oracle
  s.priceTime   === observedAt
  s.publishedAt === now

testQuoteConsumerRejectsWrongFeed : Script ()
testQuoteConsumerRejectsWrongFeed = do
  oracle <- allocateParty "ExampleOracle"
  seller <- allocateParty "Seller"
  buyer  <- allocateParty "Buyer"
  now    <- getTime
  quoteCid <- submit oracle $ createCmd PriceQuote with
    oracle, feedId = "ETH/USD", price = 3200.0, priceTime = now, publishedAt = now
  offerCid <- submit seller $ createCmd QuoteTradeOffer with
    seller, buyer, feedId = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    quoteCid = toInterfaceContractId @PublishedQuote quoteCid
  Some disc <- queryDisclosure oracle quoteCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptQuoteTrade) "feed mismatch"

testQuoteUpdateRequiresIncreasingTime : Script ()
testQuoteUpdateRequiresIncreasingTime = do
  oracle <- allocateParty "ExampleOracle"
  now    <- getTime
  quoteCid <- submit oracle $ createCmd PriceQuote with
    oracle, feedId = "BTC/USD", price = 65000.0, priceTime = now, publishedAt = now
  submitFailsWithNoDisclosure oracle
    (exerciseCmd quoteCid UpdateQuote with
       newPrice = 66000.0, newPriceTime = now, newPublishedAt = now)
    "publication time must increase"

testProducerUpdatesQuote : Script ()
testProducerUpdatesQuote = do
  oracle <- allocateParty "ExampleOracle"
  now    <- getTime
  quoteCid <- submit oracle $ createCmd PriceQuote with
    oracle, feedId = "BTC/USD", price = 65000.0, priceTime = now, publishedAt = now
  let published = addRelTime now (minutes 2)
      observed  = addRelTime now (minutes 1)
  newCid <- submit oracle $ exerciseCmd quoteCid UpdateQuote with
    newPrice = 66000.0, newPriceTime = observed, newPublishedAt = published
  old <- queryContractId oracle quoteCid
  assertMsg "stale publication must be archived" (isNone old)
  Some v <- queryInterfaceContractId oracle
    (toInterfaceContractId @PublishedQuote newCid)
  v.quote.price     === 66000.0
  v.quote.priceTime === observed
  v.publishedAt     === published

-- An offer snapshots a specific contract id, so a producer refresh archives
-- it and the late accept fails outright instead of trading on stale data.
testQuoteAcceptFailsAfterRefresh : Script ()
testQuoteAcceptFailsAfterRefresh = do
  oracle <- allocateParty "ExampleOracle"
  seller <- allocateParty "Seller"
  buyer  <- allocateParty "Buyer"
  now    <- getTime
  quoteCid <- submit oracle $ createCmd PriceQuote with
    oracle, feedId = "BTC/USD", price = 65000.0, priceTime = now, publishedAt = now
  offerCid <- submit seller $ createCmd QuoteTradeOffer with
    seller, buyer, feedId = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    quoteCid = toInterfaceContractId @PublishedQuote quoteCid
  Some disc <- queryDisclosure oracle quoteCid
  let later = addRelTime now (minutes 1)
  _ <- submit oracle $ exerciseCmd quoteCid UpdateQuote with
    newPrice = 66000.0, newPriceTime = later, newPublishedAt = later
  submitFailsMatching buyer disc (exerciseCmd offerCid AcceptQuoteTrade)
    isContractNotFound "the refreshed quote's old contract id is gone"

-- The data-point consumer rejects a publication from a distributor other than
-- the one the offer pins: the standard makes `distributor` authentic, trusting
-- it is the consumer's gate.
testDataConsumerRejectsUntrustedDistributor : Script ()
testDataConsumerRejectsUntrustedDistributor = do
  oracle  <- allocateParty "ExampleOracle"
  other   <- allocateParty "OtherOracle"
  seller  <- allocateParty "Seller"
  buyer   <- allocateParty "Buyer"
  now     <- getTime
  priceCid <- submit oracle $ createCmd PublishedPrice with
    oracle, assetPair = "BTC/USD", price = 65000.0, at = now
  offerCid <- submit seller $ createCmd TradeOffer with
    seller, buyer, assetPair = "BTC/USD", quantity = 0.5
    expectedDistributor = other, maxQuoteAge = hours 24
    priceDataCid = toInterfaceContractId @PublishedData priceCid
  Some disc <- queryDisclosure oracle priceCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptTrade) "untrusted distributor"

-- The data-point consumer rejects a publication older than its staleness bound:
-- the price is two hours old and the offer admits at most one hour.
testDataConsumerRejectsStaleData : Script ()
testDataConsumerRejectsStaleData = do
  oracle  <- allocateParty "ExampleOracle"
  seller  <- allocateParty "Seller"
  buyer   <- allocateParty "Buyer"
  now     <- getTime
  priceCid <- submit oracle $ createCmd PublishedPrice with
    oracle, assetPair = "BTC/USD", price = 65000.0
    at = addRelTime now (hours (-2))
  offerCid <- submit seller $ createCmd TradeOffer with
    seller, buyer, assetPair = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 1
    priceDataCid = toInterfaceContractId @PublishedData priceCid
  Some disc <- queryDisclosure oracle priceCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptTrade) "data too stale"

-- The quote consumer rejects a quote from a distributor other than the one the
-- offer pins, the same distributor gate as the data-point consumer.
testQuoteConsumerRejectsUntrustedDistributor : Script ()
testQuoteConsumerRejectsUntrustedDistributor = do
  oracle  <- allocateParty "ExampleOracle"
  other   <- allocateParty "OtherOracle"
  seller  <- allocateParty "Seller"
  buyer   <- allocateParty "Buyer"
  now     <- getTime
  quoteCid <- submit oracle $ createCmd PriceQuote with
    oracle, feedId = "BTC/USD", price = 65000.0, priceTime = now, publishedAt = now
  offerCid <- submit seller $ createCmd QuoteTradeOffer with
    seller, buyer, feedId = "BTC/USD", quantity = 0.5
    expectedDistributor = other, maxQuoteAge = hours 24
    quoteCid = toInterfaceContractId @PublishedQuote quoteCid
  Some disc <- queryDisclosure oracle quoteCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptQuoteTrade) "untrusted distributor"

-- The quote consumer rejects a quote older than its staleness bound: the quote
-- was produced two hours ago and the offer admits at most one hour.
testQuoteConsumerRejectsStaleQuote : Script ()
testQuoteConsumerRejectsStaleQuote = do
  oracle  <- allocateParty "ExampleOracle"
  seller  <- allocateParty "Seller"
  buyer   <- allocateParty "Buyer"
  now     <- getTime
  let producedAt = addRelTime now (hours (-2))
  quoteCid <- submit oracle $ createCmd PriceQuote with
    oracle, feedId = "BTC/USD", price = 65000.0
    priceTime = producedAt, publishedAt = producedAt
  offerCid <- submit seller $ createCmd QuoteTradeOffer with
    seller, buyer, feedId = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 1
    quoteCid = toInterfaceContractId @PublishedQuote quoteCid
  Some disc <- queryDisclosure oracle quoteCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptQuoteTrade) "quote too stale"

-- The data-point consumer rejects a publication stamped in the future: a
-- negative age must not read as fresh.
testDataConsumerRejectsFutureDatedData : Script ()
testDataConsumerRejectsFutureDatedData = do
  oracle  <- allocateParty "ExampleOracle"
  seller  <- allocateParty "Seller"
  buyer   <- allocateParty "Buyer"
  now     <- getTime
  priceCid <- submit oracle $ createCmd PublishedPrice with
    oracle, assetPair = "BTC/USD", price = 65000.0
    at = addRelTime now (hours 2)
  offerCid <- submit seller $ createCmd TradeOffer with
    seller, buyer, assetPair = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    priceDataCid = toInterfaceContractId @PublishedData priceCid
  Some disc <- queryDisclosure oracle priceCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptTrade) "data published in the future"

-- The quote consumer rejects a quote stamped in the future, the same future-age
-- guard as the data-point consumer.
testQuoteConsumerRejectsFutureDatedQuote : Script ()
testQuoteConsumerRejectsFutureDatedQuote = do
  oracle  <- allocateParty "ExampleOracle"
  seller  <- allocateParty "Seller"
  buyer   <- allocateParty "Buyer"
  now     <- getTime
  let producedAt = addRelTime now (hours 2)
  quoteCid <- submit oracle $ createCmd PriceQuote with
    oracle, feedId = "BTC/USD", price = 65000.0
    priceTime = producedAt, publishedAt = producedAt
  offerCid <- submit seller $ createCmd QuoteTradeOffer with
    seller, buyer, feedId = "BTC/USD", quantity = 0.5
    expectedDistributor = oracle, maxQuoteAge = hours 24
    quoteCid = toInterfaceContractId @PublishedQuote quoteCid
  Some disc <- queryDisclosure oracle quoteCid
  submitFailsWith buyer disc (exerciseCmd offerCid AcceptQuoteTrade) "quote published in the future"
